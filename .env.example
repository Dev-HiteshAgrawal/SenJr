# =============================================================================
# SenJr environment inventory
# - VITE_* vars are embedded in the client bundle by Vite (public).
# - Unprefixed server vars are for Netlify Functions / local Vite middleware only.
# =============================================================================

# --- Firebase (client) ---
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.region.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# --- Firebase Admin (server only — Netlify Functions, optional locally) ---
# Full service account JSON on one line, or set in Netlify as a secret.
# Required for verifyIdToken on POST /api/livekit-token (matches local dev handler).
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- AI (client; Gemini tutor) ---
VITE_GEMINI_API_KEY=your_gemini_api_key

# --- LiveKit (client URL + server credentials) ---
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
# Prefer server-only secrets (also accepted: VITE_LIVEKIT_* for local convenience)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# VITE_LIVEKIT_API_KEY=
# VITE_LIVEKIT_API_SECRET=

# --- Public site URL (optional; certificates use window.location.origin if unset) ---
VITE_PUBLIC_SITE_URL=https://your-site.netlify.app

# --- Admin ---
ADMIN_EMAIL=admin@example.com
# Shown in client for admin UI gating (non-secret identifier)
VITE_ADMIN_EMAIL=admin@example.com

# --- Referenced in AGENTS.md / legacy docs (set only if you use these products) ---
# NVIDIA_API_KEY=
# GEMINI_API_KEY=
# DAILY_API_KEY=
