# =============================================================================
# Netlify setup — copy names into Site settings → Environment variables
# =============================================================================
#
# SCOPE (critical — common mistake):
# - All VITE_* : enable for “Builds” (and usually “Functions” does not need them unless
#   you read process.env.VITE_* in a function). The browser bundle is created at build time;
#   if VITE_* are “Runtime only”, the SPA will ship with empty Firebase/Gemini/LiveKit URL.
# - FIREBASE_SERVICE_ACCOUNT_JSON, LIVEKIT_API_KEY, LIVEKIT_API_SECRET, ADMIN_EMAIL :
#   enable for “Functions” (and Builds if you ever import them in vite.config; you don’t).
#
# FIREBASE CONSOLE (not env vars — required once per domain):
# - Authentication → Settings → Authorized domains: add your Netlify hostname
#   (e.g. your-site.netlify.app and any custom domain).
#
# =============================================================================
# A) Core app (auth, Firestore, Storage, UI) — client, REQUIRED at build
# =============================================================================
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=          # optional; analytics skipped if empty
#
# =============================================================================
# B) AI Tutor — client, REQUIRED at build if you use /ai-tutor
# =============================================================================
# VITE_GEMINI_API_KEY=
#
# =============================================================================
# C) Video (LiveKit) — client URL at build; secrets at function runtime
# =============================================================================
# VITE_LIVEKIT_URL=                       # wss://…livekit.cloud
# LIVEKIT_API_KEY=                        # server-only (preferred)
# LIVEKIT_API_SECRET=                     # server-only (preferred)
#   # Alternatives read by server/env.js (less ideal — duplicates secrets in client bundle):
# VITE_LIVEKIT_API_KEY=
# VITE_LIVEKIT_API_SECRET=
#
# =============================================================================
# D) LiveKit token API — Functions only (Firebase Admin)
# =============================================================================
# FIREBASE_SERVICE_ACCOUNT_JSON=        # full service account JSON (one line or Netlify multiline secret)
#   # Aliases also supported in server/auth.js:
# GOOGLE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT=
#
# Optional: server reads project for Firestore REST without VITE_ prefix:
# FIREBASE_PROJECT_ID=
#
# =============================================================================
# E) Admin / runtime-config
# =============================================================================
# ADMIN_EMAIL=                            # server: runtime-config “admin configured”
# VITE_ADMIN_EMAIL=                       # client: AdminPanel gate (build-time)
#
# =============================================================================
# F) Optional branding / links
# =============================================================================
# VITE_PUBLIC_SITE_URL=                   # canonical links (e.g. certificates); else window.origin
#
# =============================================================================
# Not used by current SPA code (safe to omit)
# =============================================================================
# VITE_FIREBASE_DATABASE_URL=            # Realtime DB; app uses Firestore only today
