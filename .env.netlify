# =============================================================================
# Netlify setup - copy names into Site settings > Environment variables
# =============================================================================
#
# Scope is critical:
# - All VITE_* values must be available to Builds. Vite embeds these into
#   the browser bundle at build time.
# - FIREBASE_SERVICE_ACCOUNT_JSON, GEMINI_API_KEY, LIVEKIT_API_KEY,
#   LIVEKIT_API_SECRET, and ADMIN_EMAIL must be available to Functions.
#
# Firebase Console:
# - Authentication > Settings > Authorized domains: add every Netlify hostname
#   and any custom production domain.
#
# =============================================================================
# A) Core app (auth, Firestore, Storage, UI) - client, required at build
# =============================================================================
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=          # optional; analytics skipped if empty
#
# =============================================================================
# B) AI Tutor - server only, required if /ai-tutor is enabled
# =============================================================================
# GEMINI_API_KEY=
#
# =============================================================================
# C) Video (LiveKit) - client URL at build; secrets at function runtime
# =============================================================================
# VITE_LIVEKIT_URL=                       # wss://...livekit.cloud
# LIVEKIT_API_KEY=                        # server-only
# LIVEKIT_API_SECRET=                     # server-only
#
# =============================================================================
# D) LiveKit token API - Functions only (Firebase Admin)
# =============================================================================
# FIREBASE_SERVICE_ACCOUNT_JSON=          # full service account JSON
# GOOGLE_SERVICE_ACCOUNT_JSON=            # optional alias
# FIREBASE_SERVICE_ACCOUNT=               # optional alias
# FIREBASE_PROJECT_ID=                    # optional server alias for project id
#
# =============================================================================
# E) Admin / runtime-config
# =============================================================================
# ADMIN_EMAIL=                            # server runtime-config flag
# VITE_ADMIN_EMAIL=                       # client AdminPanel gate
#
# =============================================================================
# F) Optional branding / links
# =============================================================================
# VITE_PUBLIC_SITE_URL=                   # canonical links; else window.origin
#
# =============================================================================
# Not used by current SPA code
# =============================================================================
# VITE_FIREBASE_DATABASE_URL=             # Realtime DB; app uses Firestore
