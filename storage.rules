rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Default: Only authenticated users can read.
    // Specific folders have stricter rules.
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }
    
    // Mentor verification documents: Only the mentor or admins can read.
    match /mentor_verification/{userId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 5 * 1024 * 1024;
    }

    // Allow authenticated users to upload to the feed folder
    match /feed/{userId}/{fileName} {
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 100 * 1024 * 1024; // 100MB limit
    }
  }
}
