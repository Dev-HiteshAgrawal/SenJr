rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read files (default)
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }
    
    // Mentor verification documents: Only owner and admins
    match /mentor_verification/{userId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId ||
                  get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 5 * 1024 * 1024;
    }

    // Community feed media
    match /feed/{userId}/{fileName} {
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 100 * 1024 * 1024; // 100MB limit
    }

    // Stories
    match /stories/{userId}/{fileName} {
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 100 * 1024 * 1024;
    }
  }
}
