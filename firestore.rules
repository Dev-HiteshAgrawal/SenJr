rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function chatMember(chatId) {
      return isAuthenticated() && chatId.matches('.*' + request.auth.uid + '.*');
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        )
        || (
          isAuthenticated()
          && changedOnly([
            'friendRequests',
            'outgoingFriendRequests',
            'friends',
            'followers',
            'following',
            'reviews',
            'averageRating',
            'totalReviews',
            'totalSessionsCompleted',
            'studentIdsHelped',
            'uniqueStudentsHelped',
            'availability'
          ])
        );
      allow delete: if isAdmin();
    }

    match /mentors/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        (request.resource.data.uid == request.auth.uid || resource.data.uid == request.auth.uid || isAdmin());
    }

    match /students/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        (request.resource.data.uid == request.auth.uid || resource.data.uid == request.auth.uid || isAdmin());
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && (
        resource.data.mentorId == request.auth.uid ||
        resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() &&
        (request.resource.data.mentorId == request.auth.uid || request.resource.data.studentId == request.auth.uid);
      allow update: if isAuthenticated() && (
        resource.data.mentorId == request.auth.uid ||
        resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /homework/{hwId} {
      allow read: if isAuthenticated() && (
        resource.data.mentorId == request.auth.uid ||
        resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && (
        request.resource.data.mentorId == request.auth.uid ||
        request.resource.data.studentId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        resource.data.mentorId == request.auth.uid ||
        resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /certificates/{certificateId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        request.resource.data.studentId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.mentorId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /ai_chats/{chatId} {
      allow read: if chatMember(chatId);
      allow create, update: if chatMember(chatId);
      allow delete: if chatMember(chatId) || isAdmin();
    }

    match /chats/{chatId} {
      allow read, create, update: if chatMember(chatId);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if chatMember(chatId);
        allow create: if chatMember(chatId) && request.resource.data.senderId == request.auth.uid;
        allow update: if chatMember(chatId) && changedOnly(['read']);
        allow delete: if isAdmin();
      }
    }

    match /mentorship_completions/{completionId} {
      allow read: if isAuthenticated() && (
        completionId.matches('.*' + request.auth.uid + '.*') || isAdmin()
      );
      allow create, update: if isAuthenticated() && (
        request.resource.data.mentorId == request.auth.uid ||
        request.resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /feed/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        changedOnly(['reactions', 'savedBy', 'shareCount', 'commentCount'])
      );
      allow delete: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && changedOnly(['likes']);
        allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && changedOnly(['viewCount', 'view_count']);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
